{
  "name": "typoguard",
  "version": "1.0.0",
  "description": "A CLI tool to detect typosquatting and dangerous scripts in dependencies",
  "main": "index.ts",
  "bin": {
    "typoguard": "src/cli.ts"
  },
  "scripts": {
    "test": "bun test",
    "scan": "bun run src/cli.ts scan",
    "preinstall": "bun run src/cli.ts preinstall"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ravvdevv/typoguard.git"
  },
  "keywords": [
    "security",
