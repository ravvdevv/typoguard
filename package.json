    "typosquat",
    "supply-chain",
    "dependencies",
    "audit"
  ],
  "author": "ravvdevv",
  "license": "MIT",
  "dependencies": {
    "commander": "14.0.3",
    "picocolors": "1.1.1",
    "fast-levenshtein": "3.0.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/fast-levenshtein": "0.0.4",
    "bun-types": "latest"
  }
}
